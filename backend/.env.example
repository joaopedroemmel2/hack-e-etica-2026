APP_NAME=FlowLog AI API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
API_PREFIX=/api
DATABASE_URL=postgresql+asyncpg://flowlog:flowlog_dev_password@localhost:5432/flowlog_db
JWT_SECRET_KEY=replace-with-a-secure-random-value-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3001
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
INITIAL_ADMIN_NAME=Administrador
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password
